<div style="font-family: Arial, sans-serif; max-width: 800px; margin: auto; padding: 20px; border: 1px solid #ccc;">
  <h1 style="color: #333;">{{title}}</h1>
  <h3 style="color: #666;">Price: {{price}}</h3>
  
  <div style="margin: 20px 0;">
    <img src="{{mainImage}}" alt="Product Image" style="max-width: 100%; border-radius: 8px;" />
  </div>

  <div style="margin: 20px 0;">
    <h4>Description</h4>
    <p>{{description}}</p>
  </div>
  
  <div style="margin: 20px 0;">
    <h4>Condition</h4>
    <p>{{condition}}</p>
  </div>
</div>
